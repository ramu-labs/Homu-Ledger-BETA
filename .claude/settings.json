{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "forge session-start"
          },
          {
            "type": "command",
            "command": "forge context"
          },
          {
            "type": "command",
            "command": "forge heartbeat"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "forge heartbeat"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "forge session-end"
          },
          {
            "type": "command",
            "command": "forge sync"
          },
          {
            "type": "command",
            "command": "forge heartbeat --end"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:homu.ramu.app)",
      "WebFetch(domain:mcp.vercel.com)",
      "WebFetch(domain:api.vercel.com)",
      "Bash(curl:https://homu.ramu.app/*)",
      "Bash(curl:https://api.vercel.com/*)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npx tsc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git stash list:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Edit(./**)",
      "Write(./**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(supabase:*)",
      "Bash(npx supabase:*)",
      "Bash(vercel:*)",
      "Bash(npx vercel:*)",
      "Bash(psql:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release:*)",
      "Edit(./.claude/settings.json)",
      "Write(./.claude/settings.json)",
      "mcp__supabase__apply_migration",
      "mcp__supabase__execute_sql",
      "mcp__supabase__deploy_edge_function",
      "mcp__supabase__create_branch",
      "mcp__supabase__delete_branch",
      "mcp__supabase__merge_branch",
      "mcp__supabase__reset_branch",
      "mcp__supabase__rebase_branch",
      "mcp__supabase__pause_project",
      "mcp__supabase__restore_project",
      "mcp__vercel__deploy_to_vercel"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "homu.ramu.app",
        "mcp.vercel.com",
        "api.vercel.com",
        "api.supabase.com",
        "*.supabase.co",
        "registry.npmjs.org"
      ]
    }
  },
  "enableAllProjectMcpServers": true
}
